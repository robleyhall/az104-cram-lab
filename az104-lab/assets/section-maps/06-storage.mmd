    classDef tier fill:#e67e22,stroke:#d35400,color:#fff
    classDef access fill:#27ae60,stroke:#1e8449,color:#fff
    classDef redundancy fill:#8e44ad,stroke:#6c3483,color:#fff

    class BlobSvcNode,FileSvcNode,QueueNode,TableNode,Container1,Container2,Block,Append,Page,Share1 storage
    class Hot,Cool,Cold,Archive tier
